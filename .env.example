# 复制本文件为 .env 并填入真实值（.env 已被 .gitignore 忽略，不会上传）
# 演示/生产部署脚本使用以下变量替代明文密码与服务器地址

# —— 服务器（部署脚本用）——
SERVER_HOST=193.112.163.147
SERVER_PASS=your_server_root_password

# —— 应用默认账号（为空则使用代码内默认 admin/admin123、guest/123）——
DEFAULT_ADMIN_PASS=admin123
DEFAULT_GUEST_PASS=123

# —— 后端配置（可选，覆盖 backend/config.py 默认值）——
DB_TYPE=sqlite
JWT_SECRET=change-me-in-production
PG_DSN=postgresql://ecms:ecms@localhost:5432/ecms
SYNC_API_KEY=change-me-in-production
